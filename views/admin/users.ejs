<% const adminUser = typeof admin !== "undefined" ? admin : null; %>
<%- include("../partials/admin-shell", { title: title, admin: adminUser }) %>
<div class="page-title">
  <div>
    <h1>Users</h1>
    <div class="muted">WhatsApp users discovered during registration and conversations.</div>
  </div>
</div>

<nav class="nav">
  <a href="/admin">Dashboard</a>
  <a href="/admin/profiles?role=all&status=pending">Profiles</a>
  <a href="/admin/leads?status=pending">Leads</a>
</nav>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Phone</th>
        <th>Language</th>
        <th>Preferred Language</th>
        <th>Location</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      <% if (users.length === 0) { %>
        <tr><td colspan="6" class="muted">No users found.</td></tr>
      <% } %>
      <% users.forEach((user) => { %>
        <tr>
          <td data-label="Name"><%= user.name %></td>
          <td data-label="Phone"><%= user.phone %></td>
          <td data-label="Language"><%= user.language %></td>
          <td data-label="Preferred Language"><%= user.preferredLanguage %></td>
          <td data-label="Location"><%= user.location %></td>
          <td data-label="Created"><%= new Date(user.createdAt).toLocaleString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <% if (page > 1) { %><a class="button secondary" href="/admin/users?page=<%= page - 1 %>">Previous</a><% } %>
  <% if (hasNextPage) { %><a class="button" href="/admin/users?page=<%= page + 1 %>">Next</a><% } %>
</div>
  </main>
</body>
</html>
