<% const adminUser = typeof admin !== "undefined" ? admin : null; %>
<%- include("../partials/admin-shell", { title: title, admin: adminUser }) %>
<% function formatList(values) { return Array.isArray(values) && values.length ? values.join(", ") : "Not listed"; } %>
<div class="page-title">
  <div>
    <h1>Profile Verification</h1>
    <div class="muted">Approve or reject marketplace registrations.</div>
  </div>
</div>

<nav class="nav">
  <a href="/admin">Dashboard</a>
  <a href="/admin/leads?status=pending">Leads</a>
  <a href="/admin/users">Users</a>
</nav>

<form class="filters" method="get" action="/admin/profiles">
  <select name="role">
    <% roles.forEach((item) => { %>
      <option value="<%= item %>" <%= item === role ? "selected" : "" %>><%= item %></option>
    <% }) %>
  </select>
  <select name="status">
    <% statuses.forEach((item) => { %>
      <option value="<%= item %>" <%= item === status ? "selected" : "" %>><%= item %></option>
    <% }) %>
  </select>
  <button type="submit">Apply filters</button>
</form>

<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Profile</th>
        <th>Type</th>
        <th>Contact</th>
        <th>Products</th>
        <th>Location</th>
        <th>Status</th>
        <th>Created</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (profiles.length === 0) { %>
        <tr><td colspan="8" class="muted">No profiles found for this filter.</td></tr>
      <% } %>
      <% profiles.forEach((profile) => { %>
        <tr>
          <td data-label="Profile">
            <strong><%= profile.name %></strong><br>
            <span class="small muted"><%= profile.companyName || "" %></span>
          </td>
          <td data-label="Type"><span class="badge"><%= profile.profileRole %></span></td>
          <td data-label="Contact">
            <%= profile.phone || "Not listed" %><br>
            <span class="small muted"><%= profile.email || "No email" %></span>
          </td>
          <td data-label="Products"><%= formatList(profile.products || profile.productsNeeded || []) %></td>
          <td data-label="Location"><%= [profile.village, profile.district, profile.city, profile.state, profile.country].filter(Boolean).join(", ") || "Not listed" %></td>
          <td data-label="Status"><span class="badge <%= profile.verificationStatus %>"><%= profile.verificationStatus %></span></td>
          <td data-label="Created"><%= new Date(profile.createdAt).toLocaleString() %></td>
          <td class="actions" data-label="Actions">
            <% if (profile.verificationStatus === "pending") { %>
              <div class="review-actions">
                <form method="post" action="/admin/profiles/<%= profile.profileRole %>/<%= profile._id %>/approve" onsubmit="return confirm('Approve this profile and notify the user?');">
                  <button class="secondary" type="submit">Approve</button>
                </form>
                <form method="post" action="/admin/profiles/<%= profile.profileRole %>/<%= profile._id %>/reject" class="reject-form">
                  <textarea name="reason" placeholder="Optional rejection reason"></textarea>
                  <button class="danger" type="submit">Reject</button>
                </form>
              </div>
            <% } else { %>
              <span class="muted small">Reviewed <%= profile.reviewedAt ? new Date(profile.reviewedAt).toLocaleString() : "—" %></span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="pagination">
  <% if (page > 1) { %><a class="button secondary" href="/admin/profiles?role=<%= role %>&status=<%= status %>&page=<%= page - 1 %>">Previous</a><% } %>
  <% if (hasNextPage) { %><a class="button" href="/admin/profiles?role=<%= role %>&status=<%= status %>&page=<%= page + 1 %>">Next</a><% } %>
</div>

<script>
  function formatList(values) {
    return Array.isArray(values) && values.length ? values.join(", ") : "Not listed";
  }
</script>
  </main>
</body>
</html>
