<% const adminUser = typeof admin !== "undefined" ? admin : null; %>
<%- include("../partials/admin-shell", { title: title, admin: adminUser }) %>

<div class="page-header">
  <h1>Buyer Leads</h1>
  <div class="subtitle">Review farmer-to-exporter requests and update lead status.</div>
</div>

<nav class="nav-bar">
  <a href="/admin"><span class="nav-icon">&#9632;</span> Dashboard</a>
  <a href="/admin/profiles?role=all&status=pending"><span class="nav-icon">&#128100;</span> Profiles</a>
  <a href="/admin/products?status=pending"><span class="nav-icon">&#128230;</span> Products</a>
  <a href="/admin/leads?status=pending" class="active"><span class="nav-icon">&#128233;</span> Leads</a>
  <a href="/admin/users"><span class="nav-icon">&#128101;</span> Users</a>
</nav>

<div class="section-card">
  <form class="filters-bar" method="get" action="/admin/leads">
    <span class="filter-label">Filter by</span>
    <select name="status">
      <% statuses.forEach((item) => { %>
        <option value="<%= item %>" <%= item === status ? "selected" : "" %>><%= item.replace("_", " ") %></option>
      <% }) %>
    </select>
    <button type="submit" class="btn btn-primary btn-sm">Apply</button>
  </form>

  <div class="table-container">
    <table>
      <thead>
        <tr>
          <th>Created</th>
          <th>Farmer</th>
          <th>Exporter</th>
          <th>Product</th>
          <th>Message</th>
          <th>Status</th>
          <th>Admin Notes</th>
          <th>Update</th>
        </tr>
      </thead>
      <tbody>
        <% if (leads.length === 0) { %>
          <tr>
            <td colspan="8">
              <div class="empty-state">
                <div class="empty-state-icon">&#128233;</div>
                <div class="empty-state-title">No leads found</div>
                <div class="empty-state-desc">No leads match the current filter.</div>
              </div>
            </td>
          </tr>
        <% } %>
        <% leads.forEach((lead) => { %>
          <tr>
            <td data-label="Created"><%= new Date(lead.createdAt).toLocaleDateString() %></td>
            <td data-label="Farmer">
              <span class="primary-text"><%= lead.farmerId?.name || "Unknown" %></span>
              <% if (lead.farmerId?.phone) { %>
                <span class="secondary-text"><%= lead.farmerId.phone %></span>
              <% } %>
            </td>
            <td data-label="Exporter">
              <span class="primary-text"><%= lead.exporterId?.companyName || "Unknown" %></span>
              <% if (lead.exporterId?.phone) { %>
                <span class="secondary-text"><%= lead.exporterId.phone %></span>
              <% } %>
            </td>
            <td data-label="Product"><%= lead.product || "—" %></td>
            <td data-label="Message"><%= lead.message.substring(0, 60) %><%= lead.message.length > 60 ? "..." : "" %></td>
            <td data-label="Status"><span class="badge <%= lead.status %>"><%= lead.status.replace("_", " ") %></span></td>
            <td data-label="Admin Notes">
              <form method="post" action="/admin/leads/<%= lead._id %>/status" style="display:flex;flex-direction:column;gap:6px;">
                <input type="hidden" name="status" value="<%= lead.status %>">
                <textarea name="notes" placeholder="Add notes..."><%= lead.adminNotes || "" %></textarea>
                <button class="btn btn-outline btn-sm" type="submit" style="width:100%;">Save</button>
              </form>
            </td>
            <td data-label="Update">
              <form method="post" action="/admin/leads/<%= lead._id %>/status" style="display:flex;flex-direction:column;gap:6px;">
                <input type="hidden" name="notes" value="<%= lead.adminNotes || "" %>">
                <select name="status">
                  <% statuses.forEach((item) => { %>
                    <option value="<%= item %>" <%= item === lead.status ? "selected" : "" %>><%= item.replace("_", " ") %></option>
                  <% }) %>
                </select>
                <button class="btn btn-primary btn-sm" type="submit" style="width:100%;">Update</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="pagination">
    <div class="pagination-info">Page <%= page %></div>
    <div class="pagination-links">
      <% if (page > 1) { %><a class="btn btn-outline" href="/admin/leads?status=<%= status %>&page=<%= page - 1 %>">&larr; Previous</a><% } %>
      <% if (hasNextPage) { %><a class="btn btn-primary" href="/admin/leads?status=<%= status %>&page=<%= page + 1 %>">Next &rarr;</a><% } %>
    </div>
  </div>
</div>
  </main>
</body>
</html>
