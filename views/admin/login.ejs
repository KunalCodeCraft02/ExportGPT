<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Login — ExportConnect</title>
  <style>
    :root {
      --bg: #f6f8f3;
      --brand: #1f7a3a;
      --brand-dark: #145c2b;
      --text: #17301f;
      --danger: #b42318;
      --border: #dce5d8;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      min-height: 100vh;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, #eef7eb, #ffffff);
      color: var(--text);
      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }
    .login-card {
      width: min(420px, calc(100% - 32px));
      background: white;
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 28px;
      box-shadow: 0 20px 60px rgba(20, 92, 43, 0.12);
    }
    h1 { margin: 0 0 8px; font-size: 28px; }
    p { margin: 0 0 22px; color: #61705f; }
    label { display: block; font-weight: 800; margin-bottom: 6px; }
    input {
      width: 100%;
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 12px;
      font: inherit;
      margin-bottom: 14px;
    }
    button {
      width: 100%;
      border: 0;
      border-radius: 999px;
      background: var(--brand);
      color: white;
      padding: 12px;
      font-weight: 900;
      cursor: pointer;
    }
    .alert {
      background: #ffe5e2;
      color: var(--danger);
      border: 1px solid #ffc9c4;
      padding: 10px 12px;
      border-radius: 12px;
      margin-bottom: 14px;
    }

    @media (max-width: 520px) {
      body { place-items: stretch; padding: 18px 0; }
      .login-card {
        width: min(100% - 16px, 420px);
        margin: 0 auto;
        padding: 22px;
        border-radius: 18px;
      }
      h1 { font-size: 25px; }
    }
  </style>
</head>
<body>
  <form class="login-card" method="post" action="/admin/login">
    <h1>Admin Login</h1>
    <p>Manage ExportConnect registrations and marketplace leads.</p>
    <% if (error) { %>
      <div class="alert">Invalid username or password.</div>
    <% } %>
    <label for="username">Username</label>
    <input id="username" name="username" autocomplete="username" required>
    <label for="password">Password</label>
    <input id="password" name="password" type="password" autocomplete="current-password" required>
    <button type="submit">Sign in</button>
  </form>
</body>
</html>
